# Alpha
clear
units		real
dimension 3
boundary        p p p
atom_style	charge
newton on
read_data       OH_3.lmp
  orthogonal box = (0 0 0) to (16.114 16.113 16.112)
  2 by 2 by 2 MPI processor grid
  reading atoms ...
  202 atoms
  read_data CPU = 0.00645656 secs

timestep 0.25

# ---------- Define Interatomic Potential ---------------------
